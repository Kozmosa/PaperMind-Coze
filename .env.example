# ====================================================================
# PaperMind — Environment Variables
# Copy this file to .env and fill in real values.
#   cp .env.example .env
# ====================================================================

# ------------------------------------------------------------------
# Server
# ------------------------------------------------------------------
PORT=9091
NODE_ENV=development

# ------------------------------------------------------------------
# PostgreSQL (local DevContainer / docker-compose service)
# ------------------------------------------------------------------
DATABASE_URL=postgresql://papermind:papermind@localhost:5432/papermind

# ------------------------------------------------------------------
# Supabase (cloud)
# Obtain from: https://supabase.com/dashboard → Project → Settings → API
# ------------------------------------------------------------------
COZE_SUPABASE_URL=
COZE_SUPABASE_ANON_KEY=
COZE_SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------------
# Supabase — Expo client-side vars (EXPO_PUBLIC_ prefix is required)
# ------------------------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=http://localhost:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ------------------------------------------------------------------
# Backend URL for Expo client
# ------------------------------------------------------------------
EXPO_PUBLIC_BACKEND_BASE_URL=http://localhost:9091
EXPO_PUBLIC_API_BASE=http://localhost:9091

# ------------------------------------------------------------------
# AI Providers (at least one required for /api/v1/ai/* endpoints)
# ------------------------------------------------------------------
# Anthropic (Claude)
ANTHROPIC_API_KEY=
# OpenAI (GPT)
OPENAI_API_KEY=

# ------------------------------------------------------------------
# Coze platform variables (set by Coze cloud; leave empty for local dev)
# ------------------------------------------------------------------
# COZE_PROJECT_ID=
# COZE_PROJECT_NAME=PaperMind
# COZE_LOG_DIR=
# COZE_PROJECT_DOMAIN_DEFAULT=
